using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;
using Nota_Fiscal.Domain.Entities;

namespace Nota_Fiscal.Infraestructure.EntitiesConfiguration;

public class NotaFiscalConfiguration : IEntityTypeConfiguration<NotaFiscal>
{
    public void Configure(EntityTypeBuilder<NotaFiscal> builder)
    {
        builder.HasKey(n => n.Id);
        builder.Property(n => n.Number).IsRequired().HasMaxLength(100);
        builder.Property(n => n.IssueDate).IsRequired();
        builder.Property(n => n.IssuerCnpj).IsRequired().HasMaxLength(20);
        builder.Property(n => n.RecipientCnpj).IsRequired().HasMaxLength(20);
        builder.Property(n => n.ClientName).HasMaxLength(200);
        builder.Property(n => n.TotalValue).HasColumnType("decimal(18,2)");
        builder.Property(n => n.Status).IsRequired();
    }

    
}